{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(git add:*)",
      "Bash(git pull:*)",
      "Bash(git switch:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr view:*)",
      "Bash(gh search issues:*)",
      "Bash(gh issue view:*)",
      "Bash(claude mcp:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Read(.credential*)",
      "Edit(.credential*)",
      "Write(.credential*)",
      "Read(*.credential*)",
      "Edit(*.credential*)",
      "Write(*.credential*)",
      "Read(**/.credential*)",
      "Edit(**/.credential*)",
      "Write(**/.credential*)",
      "Read(**/*.credential*)",
      "Edit(**/*.credential*)",
      "Write(**/*.credential*)",
      "Read(.secret*)",
      "Edit(.secret*)",
      "Write(.secret*)",
      "Read(*.secret*)",
      "Edit(*.secret*)",
      "Write(*.secret*)",
      "Read(**/.secret*)",
      "Edit(**/.secret*)",
      "Write(**/.secret*)",
      "Read(**/*.secret*)",
      "Edit(**/*.secret*)",
      "Write(**/*.secret*)",
      "Read(master.key*)",
      "Edit(master.key*)",
      "Write(master.key*)",
      "Read(**/master.key*)",
      "Edit(**/master.key*)",
      "Write(**/master.key*)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Write(~/.aws/**)",
      "Read(**/.aws/**)",
      "Edit(**/.aws/**)",
      "Write(**/.aws/**)",
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Read(**/.ssh/**)",
      "Edit(**/.ssh/**)",
      "Write(**/.ssh/**)",
      "Read(secrets/**)",
      "Edit(secrets/**)",
      "Write(secrets/**)",
      "Read(**/secrets/**)",
      "Edit(**/secrets/**)",
      "Write(**/secrets/**)",
      "Read(credentials/**)",
      "Edit(credentials/**)",
      "Write(credentials/**)",
      "Read(**/credentials/**)",
      "Edit(**/credentials/**)",
      "Write(**/credentials/**)",
      "Read(log/**)",
      "Edit(log/**)",
      "Write(log/**)",
      "Read(**/log/**)",
      "Edit(**/log/**)",
      "Write(**/log/**)",
      "Read(tmp/**)",
      "Edit(tmp/**)",
      "Write(tmp/**)",
      "Read(**/tmp/**)",
      "Edit(**/tmp/**)",
      "Write(**/tmp/**)",
      "Read(.git/**)",
      "Edit(.git/**)",
      "Write(.git/**)",
      "Read(**/.git/**)",
      "Edit(**/.git/**)",
      "Write(**/.git/**)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(chown:*)"
    ]
  },
  "alwaysThinkingEnabled": true,
  "disableBypassPermissionsMode": true
}
